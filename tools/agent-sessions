#!/usr/bin/env python3
"""
List local coding-agent sessions for the current git repository.

Mirrors the macOS app: merge per-agent disk scans (same stores as UI indexers)
with Agent Sessions index.db (session_meta) when rows exist. Only Codex/Claude
are persisted to session_meta today; other agents are disk-sourced in-app too.
"""

from __future__ import annotations

import argparse
import importlib.util
import json
import os
import sqlite3
import subprocess
import sys
from dataclasses import dataclass, field
from datetime import datetime
from pathlib import Path
from typing import Optional


def _load_disk_module():
    path = Path(__file__).resolve().parent / "agent_sessions_disk.py"
    spec = importlib.util.spec_from_file_location("agent_sessions_disk", path)
    if spec is None or spec.loader is None:
        raise RuntimeError(f"Cannot load disk module from {path}")
    mod = importlib.util.module_from_spec(spec)
    sys.modules["agent_sessions_disk"] = mod
    spec.loader.exec_module(mod)
    return mod


_DISK = _load_disk_module()
DISK_FETCHERS = _DISK.DISK_FETCHERS

INDEX_REL = Path("Library/Application Support/AgentSessions/index.db")

