@dataclass
class SessionRow:
    source: str
    session_id: str
    title: str
    modified: str
    sort_ts: int
    cwd: Optional[str]
    repo: Optional[str]
    model: Optional[str]
    codex_internal_session_id: Optional[str] = None
    messages: int = 0
    origin: str = "index"  # index | disk
    resume_hint: str = field(default="")

    def short_id(self, n: int = 12) -> str:
        return self.session_id[:n] if len(self.session_id) > n else self.session_id

    def finish(self) -> SessionRow:
        if not self.resume_hint:
            self.resume_hint = build_resume_hint(
                self.source,
                self.session_id,
                self.cwd,
                self.codex_internal_session_id,
            )
        return self


def index_db_path() -> Path:
    return Path.home() / INDEX_REL


def resolve_agent(name: Optional[str]) -> Optional[str]:
    if name is None:
        return None
    key = name.strip().lower()
    if key in AGENTS:
        return AGENTS[key]
    known = ", ".join(sorted(set(AGENTS.keys())))
    print(f"Unknown agent {name!r}. Known aliases: {known}", file=sys.stderr)
    sys.exit(2)


def git_root(start: Path) -> Optional[Path]:
    try:
        out = subprocess.run(
            ["git", "-C", str(start), "rev-parse", "--show-toplevel"],
            capture_output=True,
            text=True,
            check=True,
            timeout=5,
        )
        root = out.stdout.strip()
        return Path(root).resolve() if root else None
    except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
        return None


def project_scope(start: Optional[Path] = None) -> tuple[Path, str]:
    base = (start or Path.cwd()).resolve()
    root = git_root(base)
    if root is not None:
        return root, root.name
    return base, base.name


def project_paths(root: Path) -> tuple[str, str]:
    root_str = str(root)
    if not root_str.endswith(os.sep):
        return root_str, root_str + os.sep
    return root_str, root_str


def try_open_index() -> Optional[sqlite3.Connection]:
    path = index_db_path()
    if not path.is_file():
        return None
    conn = sqlite3.connect(f"file:{path}?mode=ro", uri=True)
    conn.row_factory = sqlite3.Row
    return conn


def shell_quote(s: str) -> str:
    if not s:
        return "''"
    if all(c.isalnum() or c in "/._-:" for c in s):
        return s
    return "'" + s.replace("'", "'\"'\"'") + "'"


def build_resume_hint(
    source: str,
    session_id: str,
    cwd: Optional[str],
    codex_internal: Optional[str] = None,
) -> str:
    prefix = f"cd {shell_quote(cwd)} && " if cwd else ""
    if source == "codex":
        rid = codex_internal or session_id
        return f"{prefix}codex resume {shell_quote(rid)}"
    if source == "claude":
        return f"{prefix}claude --resume {shell_quote(session_id)}"
    if source == "opencode":
        return f"{prefix}opencode --session {shell_quote(session_id)}"
    if source == "gemini":
        return f"{prefix}gemini --resume {shell_quote(session_id)}"
    if source == "hermes":
        return f"{prefix}hermes --resume {shell_quote(session_id)}"
    if source == "copilot":
        return f"{prefix}copilot --resume {shell_quote(session_id)}"
    if source == "cursor":
        return f"{prefix}cursor agent --resume {shell_quote(session_id)}"
    if source == "pi":
        return f"{prefix}pi --resume {shell_quote(session_id)}"
    if source == "grok":
        return f"{prefix}grok -r {shell_quote(session_id)}"
    if source == "amp":
        return f"{prefix}amp threads continue {shell_quote(session_id)}"
    if source == "antigravity":
        return f"{prefix}agy --conversation {shell_quote(session_id)}"
    if source == "droid":
        return f"{prefix}droid resume {shell_quote(session_id)}"
    if source == "openclaw":
        return f"{prefix}openclaw resume {shell_quote(session_id)}"
    return f"{prefix}# resume not documented for {source}; session_id={session_id}"


def format_ts(ts: int) -> tuple[str, int]:
    if ts <= 0:
        return "—", 0
    return datetime.fromtimestamp(ts).strftime("%Y-%m-%d %H:%M:%S"), ts


def fetch_sessions_index(
    conn: sqlite3.Connection,
    root: Path,
    repo_label: str,
    agent: Optional[str],
    limit: Optional[int],
    include_housekeeping: bool,
) -> list[SessionRow]:
    root_str, root_prefix = project_paths(root)
    clauses = ["(cwd = ? OR cwd LIKE ? OR repo = ? OR repo LIKE ?)"]
    binds: list[object] = [root_str, root_prefix + "%", repo_label, f"%{repo_label}%"]
    if agent:
        clauses.append("source = ?")
        binds.append(agent)
    if not include_housekeeping:
        clauses.append("(is_housekeeping = 0 OR is_housekeeping IS NULL)")
    where = " AND ".join(clauses)
    limit_sql = f" LIMIT {int(limit)}" if limit else ""
    sql = f"""
        SELECT session_id, source, cwd, repo, model, title, custom_title,
               codex_internal_session_id, messages,
               COALESCE(end_ts, mtime) AS sort_ts
        FROM session_meta
        WHERE {where}
        ORDER BY sort_ts DESC
        {limit_sql}
    """
    rows: list[SessionRow] = []
    for r in conn.execute(sql, binds).fetchall():
        title = (r["custom_title"] or r["title"] or "").strip() or "(no title)"
        ts = int(r["sort_ts"] or 0)
        modified, sort_ts = format_ts(ts)
        rows.append(
            SessionRow(
                source=r["source"],
                session_id=r["session_id"],
                title=title,
                modified=modified,
                sort_ts=sort_ts,
                cwd=r["cwd"],
                repo=r["repo"],
                model=r["model"],
                codex_internal_session_id=r["codex_internal_session_id"],
                messages=int(r["messages"] or 0),
                origin="index",
            ).finish()
        )
    return rows


def global_index_counts(conn: sqlite3.Connection) -> dict[str, int]:
    cur = conn.execute(
        "SELECT source, COUNT(*) AS n FROM session_meta GROUP BY source ORDER BY source"
    )
    return {row["source"]: row["n"] for row in cur.fetchall()}


def agent_data_present() -> dict[str, bool]:
    """True when the agent's default on-disk store path exists (not necessarily CLI-readable)."""
    home = Path.home()
    checks = {
        "codex": home / ".codex" / "sessions",
        "claude": home / ".claude",
        "gemini": home / ".gemini" / "tmp",
        "opencode": home / ".local/share/opencode/opencode.db",
        "hermes": home / ".hermes" / "sessions",
        "copilot": home / ".copilot",
        "droid": home / ".factory",
        "openclaw": home / ".openclaw",
        "cursor": home / ".cursor" / "projects",
        "pi": home / ".pi" / "agent" / "sessions",
        "grok": _DISK.grok_sessions_root(),
        "amp": _DISK.amp_sessions_root(),
        "antigravity": _DISK.antigravity_sessions_root(),
    }
    return {k: v.exists() for k, v in checks.items()}


def cli_disk_listable(data_present: Optional[dict[str, bool]] = None) -> dict[str, bool]:
    """True when this CLI has a disk scanner and the agent store path exists."""
    present = data_present if data_present is not None else agent_data_present()
    return {source: present.get(source, False) for source in DISK_FETCHERS}


def row_from_disk_dict(d: dict) -> SessionRow:
    return SessionRow(
        source=d["source"],
        session_id=d["session_id"],
        title=d["title"],
        modified=d["modified"],
        sort_ts=d["sort_ts"],
        cwd=d.get("cwd"),
        repo=d.get("repo"),
        model=d.get("model"),
        codex_internal_session_id=d.get("codex_internal_session_id"),
        messages=int(d.get("messages") or 0),
        origin="disk",
    ).finish()


def fetch_sessions_index_for_source(
    conn: sqlite3.Connection,
    source: str,
    root: Path,
    repo_label: str,
    include_housekeeping: bool,
) -> list[SessionRow]:
    return fetch_sessions_index(
        conn, root, repo_label, source, None, include_housekeeping
    )


def _row_identity_keys(row: SessionRow) -> set[tuple[str, str]]:
    """Identity keys for dedup. Index and disk store different ids for the same
    Codex session (index keys on the file content hash, disk on the internal
    session uuid), so also match on codex_internal_session_id when present."""
    keys = {(row.source, row.session_id)}
    if row.codex_internal_session_id:
        keys.add((row.source, row.codex_internal_session_id))
    return keys


def merge_session_rows(
    index_rows: list[SessionRow],
    disk_rows: list[SessionRow],
) -> list[SessionRow]:
    seen: set[tuple[str, str]] = set()
    merged: list[SessionRow] = []
    for row in (*index_rows, *disk_rows):
        keys = _row_identity_keys(row)
        if seen & keys:
            continue
        seen |= keys
        merged.append(row)
    merged.sort(key=lambda r: r.sort_ts, reverse=True)
    return merged


def collect_sessions(
    root: Path,
    repo_label: str,
    agent: Optional[str],
    limit: Optional[int],
    include_housekeeping: bool,
    index_only: bool,
) -> tuple[list[SessionRow], dict[str, int], dict[str, bool], dict[str, bool]]:
    sources = [agent] if agent else list(ALL_SOURCES)
    global_index: dict[str, int] = {}
    conn = try_open_index()
    if conn:
        try:
            global_index = global_index_counts(conn)
        except sqlite3.Error:
            pass

    merged: list[SessionRow] = []
    try:
        for source in sources:
            index_rows: list[SessionRow] = []
            if conn:
                index_rows = fetch_sessions_index_for_source(
                    conn, source, root, repo_label, include_housekeeping
                )
            if index_only:
                merged.extend(index_rows)
                continue
            disk_rows: list[SessionRow] = []
            fetcher = DISK_FETCHERS.get(source)
            if fetcher:
                disk_rows = [row_from_disk_dict(d) for d in fetcher(root, repo_label, None)]
            merged.extend(merge_session_rows(index_rows, disk_rows))
    finally:
        if conn:
            conn.close()

    merged.sort(key=lambda r: r.sort_ts, reverse=True)
    if limit:
        merged = merged[: int(limit)]
    data_present = agent_data_present()
    return merged, global_index, data_present, cli_disk_listable(data_present)


def print_table(rows: list[SessionRow], show_resume: bool, show_origin: bool) -> None:
    if not rows:
        print("No sessions found for this project.")
        return

    modified_w = 19
    msgs_w = 5
    id_w = max(len(r.short_id()) for r in rows)
    id_w = max(id_w, 2)
    agent_w = max(len(r.source) for r in rows)
    agent_w = max(agent_w, 5)
    title_w = min(56, max(len(r.title) for r in rows))
    origin_w = 6 if show_origin else 0
    origin_hdr = "  SRC" if show_origin else ""

    header = (
        f"{'ID':<{id_w}}  {'AGENT':<{agent_w}}  {'MODIFIED':<{modified_w}}  "
        f"{'MSGS':>{msgs_w}}{origin_hdr}  TITLE"
    )
    print(header)
    print("-" * len(header))

    # Columns through MSGS (+ optional SRC), plus two spaces before TITLE.
    data_width = id_w + 2 + agent_w + 2 + modified_w + 2 + msgs_w + origin_w + 2

    for r in rows:
        title = r.title if len(r.title) <= title_w else r.title[: title_w - 2] + ".."
        origin = f"  {r.origin[:4]:>4}" if show_origin else ""
        print(
            f"{r.short_id():<{id_w}}  {r.source:<{agent_w}}  {r.modified:<{modified_w}}  "
            f"{r.messages:>{msgs_w}}{origin}  {title}"
        )
        if show_resume:
            print(f"{'':>{data_width}}  resume: {r.resume_hint}")


def cmd_list(args: argparse.Namespace) -> int:
    agent = resolve_agent(args.agent)
    root, repo_label = project_scope(Path(args.cwd) if args.cwd else None)

    rows, global_index, _, _ = collect_sessions(
        root,
        repo_label,
        agent,
        args.limit,
        args.include_housekeeping,
        index_only=args.index_only,
    )

    if args.json:
        payload = {
            "project_root": str(root),
            "repo_label": repo_label,
            "agent_filter": agent,
            "index_only": args.index_only,
            "index_sources_present": sorted(global_index.keys()),
            "count": len(rows),
            "sessions": [
                {
                    "id": r.session_id,
                    "short_id": r.short_id(),
                    "agent": r.source,
                    "title": r.title,
                    "modified": r.modified,
                    "cwd": r.cwd,
                    "repo": r.repo,
                    "model": r.model,
                    "messages": r.messages,
                    "origin": r.origin,
                    "resume": r.resume_hint,
                }
                for r in rows
            ],
        }
        print(json.dumps(payload, indent=2))
        return 0

    scope = f"{root} (repo: {repo_label})"
    if agent:
        scope += f", agent: {DISPLAY_NAMES.get(agent, agent)}"
    print(f"Project: {scope}\n")

    show_origin = not args.index_only and any(r.origin == "disk" for r in rows)
    print_table(rows, show_resume=args.resume, show_origin=show_origin)
    if rows:
        suffix = ""
        if show_origin:
            suffix = " (SRC: index=Agent Sessions DB, disk=read from agent files)"
        print(f"\n{len(rows)} session(s). Use --resume for resume commands.{suffix}")
    needs_app_index = sorted(set(ALL_SOURCES) - set(global_index.keys()))
    if needs_app_index and not args.index_only:
        print(
            "\nNote: Not in session_meta index (Codex/Claude write there; enable other agents "
            "in Settings → Agents for faster index hydration): "
            + ", ".join(needs_app_index)
            + ". Listed via disk scan when store files exist.",
        )
    return 0


def project_counts_by_source(rows: list[SessionRow]) -> dict[str, dict[str, int]]:
    out: dict[str, dict[str, int]] = {}
    for row in rows:
        bucket = out.setdefault(row.source, {"index": 0, "disk": 0, "total": 0})
        bucket[row.origin] = bucket.get(row.origin, 0) + 1
        bucket["total"] += 1
    return out


def cmd_agents(args: argparse.Namespace) -> int:
    root, repo_label = project_scope(Path(args.cwd) if args.cwd else None)
    rows, global_index, data_present, cli_listable = collect_sessions(
        root,
        repo_label,
        agent=None,
        limit=None,
        include_housekeeping=False,
        index_only=args.index_only,
    )
    counts = project_counts_by_source(rows)

    print(f"Project: {root} (repo: {repo_label})\n")
    print(f"{'AGENT':<10} {'PROJ':>5}  {'idx':>5}  {'disk':>5}  NAME")
    print("-" * 52)
    for source in ALL_SOURCES:
        c = counts.get(source, {"index": 0, "disk": 0, "total": 0})
        label = DISPLAY_NAMES.get(source, source)
        g = global_index.get(source, 0)
        data = "yes" if data_present.get(source) else "no"
        cli = "yes" if cli_listable.get(source) else "no"
        extra = f"  (index: {g}, data: {data}, cli-list: {cli})"
        print(
            f"{source:<10} {c['total']:>5}  {c['index']:>5}  {c['disk']:>5}  {label}{extra}"
        )
    print("\nRun: agent-sessions list [agent]   e.g. agent-sessions list opencode")
    if not args.index_only:
        print("All agents: disk scan; index rows merged when present (usually codex/claude).")
    return 0


def cmd_sources(args: argparse.Namespace) -> int:
    conn = try_open_index()
    global_index: dict[str, int] = {}
    if conn:
        try:
            global_index = global_index_counts(conn)
        finally:
            conn.close()
    else:
        print(f"Index not found: {index_db_path()}\n", file=sys.stderr)

    data_present = agent_data_present()
    cli_listable = cli_disk_listable(data_present)
    print("Agent Sessions supported sources:\n")
    print(f"{'SOURCE':<10} {'INDEX':>8}  {'DATA':<5}  {'CLI':<5}  STORAGE")
    print("-" * 68)
    print("  DATA = store path exists; CLI = this tool can list from disk without session_meta\n")
    for source in ALL_SOURCES:
        g = global_index.get(source, 0)
        data = "yes" if data_present.get(source) else "no"
        cli = "yes" if cli_listable.get(source) else "no"
        hint = DISK_STORE_HINTS.get(source, "")
        print(f"{source:<10} {g:>8}  {data:<5}  {cli:<5}  {hint}")

    indexed = sorted(global_index.keys())
    not_indexed = [s for s in ALL_SOURCES if s not in global_index]
    if not_indexed:
        print(
            "\nYour index currently only includes: "
            + (", ".join(indexed) if indexed else "(none)")
        )
        print(
            "To index the rest: Agent Sessions → Settings → enable each agent, "
            "then leave the app open to scan."
        )
        print(
            "CLI=yes means disk scan works; session_meta may still be empty until the app indexes."
        )
    return 0


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="agent-sessions",
        description=(
            "List local coding-agent sessions for the current git repository. "
            "Merges Agent Sessions index (session_meta) with per-agent disk scans (UI parity)."
        ),
    )
    p.add_argument(
        "--cwd",
        metavar="PATH",
        help="Directory to resolve project from (default: current directory)",
    )
    index_flag = argparse.ArgumentParser(add_help=False)
    index_flag.add_argument(
        "--index-only",
        action="store_true",
        help="Only use session_meta from index.db (no disk scan; usually codex/claude only)",
    )
    sub = p.add_subparsers(dest="command", required=True)

    list_p = sub.add_parser("list", parents=[index_flag], help="List sessions for this project")
    list_p.add_argument(
        "agent",
        nargs="?",
        help="Filter: codex, claude, opencode, pi, cursor, gemini, copilot, hermes, openclaw, droid",
    )
    list_p.add_argument("--limit", type=int, metavar="N", help="Max rows to return")
    list_p.add_argument("--json", action="store_true", help="Emit JSON")
    list_p.add_argument("--resume", action="store_true", help="Print resume commands")
    list_p.add_argument("--include-housekeeping", action="store_true")
    list_p.set_defaults(func=cmd_list)

    agents_p = sub.add_parser(
        "agents", parents=[index_flag], help="Session counts per agent for this project"
    )
    agents_p.set_defaults(func=cmd_agents)

    sources_p = sub.add_parser(
        "sources", help="Global index vs on-disk store for each supported agent"
    )
    sources_p.set_defaults(func=cmd_sources)

    return p


def main(argv: Optional[list[str]] = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return int(args.func(args))


if __name__ == "__main__":
    sys.exit(main())