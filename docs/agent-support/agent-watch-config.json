{
  "report_root": "scripts/probe_scan_output/agent_watch",
  "agents": {
    "codex": {
      "cadence": { "daily": true, "weekly": true },
      "installed_version_cmd": ["codex", "--version"],
      "verified_version_source": "docs/agent-support/agent-support-matrix.yml#agents.codex_cli.max_verified_version",
      "upstream": [
        { "kind": "github_latest_release", "repo": "openai/codex" }
      ],
      "risk_keywords": {
        "schema": ["session", "transcript", "json", "jsonl", "format", "logging", "migration"],
        "usage": ["usage", "token", "tokens", "rate", "limit", "quota", "status"]
      },
      "weekly": {
        "local_schema": {
          "kind": "jsonl_newest",
          "roots": ["$CODEX_HOME/sessions", "~/.codex/sessions"],
          "glob": "**/rollout-*.jsonl",
          "required_types": ["session_meta"],
          "max_lines": 2500
        },
        "freshness_window_days": 14,
        "discovery_path_contract": {
          "description": "Codex sessions should be discovered from day folders under a sessions root.",
          "patterns": ["/sessions/[0-9]{4}/[0-9]{2}/[0-9]{2}/rollout-[^/]+\\.jsonl$"]
        },
        "probes": [
          {
            "kind": "script",
            "label": "codex_status_probe",
            "argv": ["./AgentSessions/Resources/codex_status_capture.sh"],
            "timeout_seconds": 45,
            "parse": "codex_status_json"
          }
        ]
      },
      "prebump": {
        "driver": "codex_exec",
        "sandbox": {"mode": "home_override", "subdir": "codex_sandbox"},
        "prompt": "List files in the current directory.",
        "timeout_seconds": 180,
        "env_vars": ["OPENAI_API_KEY"],
        "credential_files": ["~/.codex/auth.json"],
        "discover_session": {
          "kind": "jsonl_newest",
          "roots": [".codex/sessions"],
          "globs": ["**/rollout-*.jsonl"],
          "required_types": ["session_meta"]
        }
      }
    },
    "claude": {
      "cadence": { "daily": true, "weekly": true },
      "installed_version_cmd": ["claude", "--version"],
      "verified_version_source": "docs/agent-support/agent-support-matrix.yml#agents.claude_code.max_verified_version",
      "upstream": [
        { "kind": "github_latest_release", "repo": "anthropics/claude-code" }
      ],
      "risk_keywords": {
        "schema": ["session", "transcript", "json", "jsonl", "format", "storage", "migration"],
        "usage": ["usage", "token", "tokens", "rate", "limit", "quota"]
      },
      "weekly": {
        "local_schema": {
          "kind": "jsonl_newest",
          "roots": ["~/.claude/projects"],
          "glob": "**/*.jsonl",
          "required_types": ["user", "assistant"],
          "max_lines": 2500
        },
        "freshness_window_days": 14,
        "discovery_path_contract": {
          "description": "Claude sessions should live under ~/.claude/projects/** with jsonl/ndjson files.",
          "patterns": ["/\\.claude/projects/.+\\.(jsonl|ndjson)$"]
        },
        "probes": [
          {
            "kind": "script",
            "label": "claude_status",
            "argv": ["./scripts/claude-status", "--json"],
            "timeout_seconds": 15,
            "parse": "claude_status_json"
          },
          {
            "kind": "script",
            "label": "claude_usage_probe",
            "argv": ["./AgentSessions/Resources/claude_usage_capture.sh"],
            "timeout_seconds": 45,
            "parse": "claude_usage_json"
          }
        ]
      },
      "prebump": {
        "driver": "claude_print",
        "sandbox": {"mode": "home_override", "subdir": "claude_sandbox"},
        "prompt": "Say hi, then use the Bash tool to run pwd.",
        "model": "sonnet",
        "real_home_session": true,
        "timeout_seconds": 180,
        "env_vars": ["ANTHROPIC_API_KEY"],
        "credential_files": ["~/.claude/.credentials.json"],
        "discover_session": {
          "kind": "jsonl_newest",
          "roots": [".claude/projects"],
          "globs": ["**/*.jsonl"],
          "required_types": ["user", "assistant"]
        }
      }
    },
    "opencode": {
      "cadence": { "daily": true, "weekly": true },
      "installed_version_cmd": ["opencode", "--version"],
      "verified_version_source": "docs/agent-support/agent-support-matrix.yml#agents.opencode.max_verified_version",
      "upstream": [
        { "kind": "github_latest_release", "repo": "anomalyco/opencode" }
      ],
      "risk_keywords": {
        "schema": ["storage", "migration", "schema", "format", "json", "jsonl", "session", "sqlite", "bolt", "bbolt", "badger", "database", "db"],
        "usage": ["usage", "token", "tokens", "limit", "quota"]
      },
      "weekly": {
        "local_schema": {
          "kind": "opencode_latest_session",
          "db_roots": ["~/.local/share/opencode/opencode.db"],
          "roots": ["~/.local/share/opencode/storage/session"],
          "glob": "**/ses_*.json",
          "max_messages": 250,
          "max_parts": 2500
        },
        "freshness_window_days": 30,
        "discovery_path_contract": {
          "description": "OpenCode sessions should come from opencode.db when SQLite is present, or storage/session/*/ses_*.json for legacy file storage.",
          "patterns": ["/opencode/opencode\\.db$", "/opencode/storage/session/.+/ses_[^/]+\\.json$"]
        },
        "probes": [
          {
            "kind": "script",
            "label": "opencode_capture",
            "argv": ["./scripts/capture_latest_agent_sessions.py", "--agent", "opencode"],
            "timeout_seconds": 60,
            "parse": "capture_latest_sessions"
          }
        ]
      },
      "prebump": {
        "driver": "opencode_run",
        "sandbox": {"mode": "home_override", "subdir": "opencode_sandbox"},
        "prompt": "Say hello in one sentence.",
        "timeout_seconds": 180,
        "env_vars": [
          "ANTHROPIC_API_KEY",
          "OPENAI_API_KEY",
          "GEMINI_API_KEY",
          "GROQ_API_KEY",
          "OPENROUTER_API_KEY"
        ],
        "credential_files": [],
        "support_files": [
          "~/.config/opencode/config.json",
          "~/.config/opencode/opencode.json",
          "~/.config/opencode/opencode.jsonc"
        ],
        "discover_session": {
          "kind": "opencode_latest_session",
          "roots": [".local/share/opencode"],
          "globs": ["opencode.db", "storage/session/**/ses_*.json"],
          "required_types": []
        }
      }
    },
    "hermes": {
      "cadence": { "daily": false, "weekly": true },
      "installed_version_cmd": ["hermes", "--version"],
      "verified_version_source": "docs/agent-support/agent-support-matrix.yml#agents.hermes.max_verified_version",
      "upstream": [
        {
          "kind": "url_regex_semver_max",
          "url": "https://raw.githubusercontent.com/NousResearch/hermes-agent/main/pyproject.toml",
          "pattern": "version\\s*=\\s*\"([0-9]+\\.[0-9]+\\.[0-9]+)\""
        }
      ],
      "risk_keywords": {
        "schema": ["session", "json", "format", "storage", "migration", "messages", "tools"],
        "usage": ["usage", "token", "tokens", "limit", "quota"]
      },
      "weekly": {
        "local_schema": {
          "kind": "hermes_latest_session",
          "db_roots": ["~/.hermes/state.db"],
          "roots": ["~/.hermes/sessions"],
          "glob": "session_*.json",
          "max_messages": 2500
        },
        "freshness_window_days": 30,
        "discovery_path_contract": {
          "description": "Hermes sessions should come from ~/.hermes/state.db, with legacy canonical JSON files under ~/.hermes/sessions as fallback.",
          "patterns": ["/\\.hermes/state\\.db$", "/\\.hermes/sessions/session_[^/]+\\.json$"]
        }
      },
      "prebump": {
        "driver": "hermes_oneshot",
        "sandbox": {"mode": "home_override", "subdir": "hermes_sandbox"},
        "prompt": "Say hello in one sentence.",
        "real_home_session": true,
        "timeout_seconds": 180,
        "env_vars": [
          "ANTHROPIC_API_KEY",
          "OPENAI_API_KEY",
          "GEMINI_API_KEY",
          "OPENROUTER_API_KEY"
        ],
        "credential_files": [],
        "support_files": ["~/.hermes/config.yaml", "~/.hermes/.env"],
        "discover_session": {
          "kind": "hermes_latest_session",
          "roots": [".hermes"],
          "globs": ["state.db", "sessions/session_*.json"],
          "required_types": []
        }
      }
    },
    "antigravity": {
      "cadence": { "daily": false, "weekly": true },
      "installed_version_cmd": ["agy", "--version"],
      "verified_version_source": "docs/agent-support/agent-support-matrix.yml#agents.antigravity.max_verified_version",
      "upstream": [],
      "risk_keywords": {
        "schema": ["session", "transcript", "markdown", "format"],
        "usage": ["usage", "token", "tokens", "limit", "quota"]
      },
      "weekly": {
        "local_schema": {
          "kind": "antigravity_markdown_newest",
          "roots": ["~/.gemini/antigravity/brain"],
          "glob": "*/*.md",
          "max_lines": 2500
        },
        "freshness_window_days": 30,
        "discovery_path_contract": {
          "description": "Antigravity brain artifacts should be under ~/.gemini/antigravity/brain/<conversation-id>/*.md.",
          "patterns": ["/\\.gemini/antigravity/brain/[^/]+/[^/]+\\.md$"]
        },
        "probes": [
          {
            "kind": "script",
            "label": "antigravity_capture",
            "argv": ["./scripts/capture_latest_agent_sessions.py", "--agent", "antigravity"],
            "timeout_seconds": 60,
            "parse": "capture_latest_sessions"
          }
        ]
      },
      "prebump": {
        "driver": "antigravity_print",
        "sandbox": {"mode": "home_override", "subdir": "antigravity_sandbox"},
        "prompt": "Say hello in one sentence.",
        "timeout_seconds": 180,
        "real_home_session": true,
        "env_vars": [],
        "credential_files": [],
        "support_files": [],
        "discover_session": {
          "kind": "antigravity_markdown_newest",
          "roots": [".gemini/antigravity/brain"],
          "globs": ["*/*.md"],
          "required_types": []
        }
      }
    },
    "copilot": {
      "cadence": { "daily": false, "weekly": true },
      "installed_version_cmd": ["copilot", "--version"],
      "verified_version_source": "docs/agent-support/agent-support-matrix.yml#agents.copilot_cli.max_verified_version",
      "upstream": [
        { "kind": "github_latest_release", "repo": "github/copilot-cli" }
      ],
      "risk_keywords": {
        "schema": ["session", "jsonl", "format", "schema"],
        "usage": ["usage", "token", "tokens", "limit", "quota"]
      },
      "weekly": {
        "local_schema": {
          "kind": "jsonl_newest",
          "roots": ["~/.copilot/session-state"],
          "glob": "**/*.jsonl",
          "max_lines": 2500
        },
        "freshness_window_days": 14,
        "discovery_path_contract": {
          "description": "Copilot sessions: flat *.jsonl at root (legacy <1.0) OR <uuid>/events.jsonl subdirectories (1.0+) under ~/.copilot/session-state.",
          "patterns": [
            "/\\.copilot/session-state/[^/]+\\.jsonl$",
            "/\\.copilot/session-state/[^/]+/events\\.jsonl$"
          ]
        }
      },
      "prebump": {
        "driver": "copilot_prompt",
        "sandbox": {"mode": "home_override", "subdir": "copilot_sandbox"},
        "prompt": "Run ls.",
        "model": "auto",
        "real_home_session": true,
        "timeout_seconds": 180,
        "env_vars": ["COPILOT_GITHUB_TOKEN", "GH_TOKEN", "GITHUB_TOKEN"],
        "credential_files": ["~/.copilot/hosts.json"],
        "discover_session": {
          "kind": "jsonl_newest",
          "roots": [".copilot/session-state"],
          "globs": ["**/events.jsonl", "**/*.jsonl"],
          "required_types": []
        }
      }
    },
    "openclaw": {
      "cadence": { "daily": true, "weekly": true },
      "installed_version_cmd": ["openclaw", "--version"],
      "verified_version_source": "docs/agent-support/agent-support-matrix.yml#agents.openclaw.max_verified_version",
      "upstream": [
        { "kind": "npm_latest", "package": "openclaw" }
      ],
      "risk_keywords": {
        "schema": ["session", "jsonl", "transcript", "storage", "format", "schema", "model", "tool"],
        "usage": ["usage", "token", "tokens", "quota", "limit"]
      },
      "weekly": {
        "local_schema": {
          "kind": "jsonl_newest",
          "roots": [
            "$OPENCLAW_STATE_DIR",
            "~/.openclaw",
            "~/.clawdbot"
          ],
          "glob": "**/*.jsonl",
          "required_types": ["session", "message"],
          "max_lines": 2500,
          "exclude_globs": [
            "backup",
            "*/backup/*",
            "*.jsonl.reset.*",
            "*.jsonl.deleted.*",
            "*.trajectory.jsonl",
            "*.jsonl.lock"
          ]
        },
        "freshness_window_days": 30,
        "discovery_path_contract": {
          "description": "OpenClaw sessions should resolve to agents/<id>/sessions/*.jsonl.",
          "patterns": ["/agents/[^/]+/sessions/(?![^/]+\\.trajectory\\.jsonl$)[^/]+\\.jsonl$"]
        },
        "probes": [
          {
            "kind": "script",
            "label": "openclaw_capture",
            "argv": ["./scripts/capture_latest_agent_sessions.py", "--agent", "openclaw"],
            "timeout_seconds": 60,
            "parse": "capture_latest_sessions"
          }
        ]
      },
      "prebump": {
        "driver": "openclaw_local_agent",
        "sandbox": {"mode": "home_override", "subdir": "openclaw_sandbox"},
        "prompt": "Say hello in one sentence.",
        "real_home_session": true,
        "timeout_seconds": 180,
        "env_vars": [
          "ANTHROPIC_API_KEY",
          "OPENAI_API_KEY",
          "GEMINI_API_KEY",
          "OPENROUTER_API_KEY"
        ],
        "credential_files": [],
        "discover_session": {
          "kind": "jsonl_newest",
          "roots": [".openclaw"],
          "globs": ["agents/*/sessions/*.jsonl"],
          "required_types": ["session", "message"]
        }
      }
    },
    "cursor": {
      "cadence": { "daily": false, "weekly": true },
      "installed_version_cmd": ["cursor-agent", "--version"],
      "installed_version_fallback_cmds": [
        ["agent", "--version"],
        ["cursor", "--version"],
        ["/Applications/Cursor.app/Contents/Resources/app/bin/cursor", "--version"],
        ["~/Applications/Cursor.app/Contents/Resources/app/bin/cursor", "--version"]
      ],
      "verified_version_source": "docs/agent-support/agent-support-matrix.yml#agents.cursor.max_verified_version",
      "upstream": [
        {
          "kind": "url_regex_semver_max",
          "url": "https://cursor.com/install",
          "pattern": "downloads\\.cursor\\.com/lab/([^/]+)/\\$\\{OS\\}/\\$\\{ARCH\\}/agent-cli-package\\.tar\\.gz",
          "note": "Official Cursor CLI installer script; do not use the unrelated npm cursor-agent package."
        },
        {
          "kind": "url_regex_semver_max",
          "url": "https://formulae.brew.sh/cask/cursor-cli",
          "pattern": "downloads\\.cursor\\.com/lab/([^/]+)/darwin/(?:arm64|x64)/agent-cli-package\\.tar\\.gz",
          "note": "Homebrew cask page fallback for Cursor CLI latest build."
        }
      ],
      "risk_keywords": {
        "schema": ["session", "transcript", "json", "jsonl", "agent-transcripts", "format", "tool_result", "thinking"],
        "usage": []
      },
      "weekly": {
        "local_schema": {
          "kind": "cursor_transcript_newest",
          "roots": ["~/.cursor/projects"],
          "glob": "**/agent-transcripts/**/*.jsonl",
          "max_lines": 2500
        },
        "freshness_window_days": 30,
        "discovery_path_contract": {
          "description": "Cursor transcripts under ~/.cursor/projects/*/agent-transcripts/*/*.jsonl",
          "patterns": ["/\\.cursor/projects/.+/agent-transcripts/.+\\.jsonl$"]
        },
        "probes": [
          {
            "kind": "script",
            "label": "cursor_sqlite_probe",
            "argv": ["./scripts/cursor_sqlite_probe.py"],
            "timeout_seconds": 30,
            "parse": "cursor_sqlite_json"
          }
        ]
      },
      "prebump": {
        "driver": "cursor_agent_print",
        "sandbox": {"mode": "home_override", "subdir": "cursor_sandbox"},
        "prompt": "Say hello in one sentence.",
        "real_home_session": true,
        "timeout_seconds": 180,
        "env_vars": ["CURSOR_API_KEY"],
        "credential_files": [],
        "discover_session": {
          "kind": "cursor_transcript_newest",
          "roots": [".cursor/projects"],
          "globs": ["**/agent-transcripts/**/*.jsonl"],
          "required_types": []
        }
      }
    },
    "pi": {
      "cadence": { "daily": false, "weekly": true },
      "installed_version_cmd": ["pi", "--version"],
      "verified_version_source": "docs/agent-support/agent-support-matrix.yml#agents.pi.max_verified_version",
      "upstream": [
        { "kind": "npm_latest", "package": "@earendil-works/pi-coding-agent" }
      ],
      "risk_keywords": {
        "schema": ["session", "jsonl", "format", "schema", "transcript", "storage", "migration"],
        "usage": ["usage", "token", "tokens", "limit", "quota"]
      },
      "weekly": {
        "local_schema": {
          "kind": "jsonl_newest",
          "roots": ["$PI_CODING_AGENT_SESSION_DIR", "~/.pi/agent/sessions"],
          "glob": "**/*.jsonl",
          "required_types": ["session", "message"],
          "max_lines": 2500
        },
        "freshness_window_days": 30,
        "discovery_path_contract": {
          "description": "Pi sessions should live under ~/.pi/agent/sessions/** as JSONL v3 files, or under the PI_CODING_AGENT_SESSION_DIR override.",
          "patterns": [
            "/\\.pi/agent/sessions/.+\\.jsonl$",
            "/pi-agent/sessions/.+\\.jsonl$"
          ]
        }
      },
      "prebump": {
        "driver": "pi_prompt",
        "sandbox": {"mode": "home_override", "subdir": "pi_sandbox"},
        "prompt": "Say hello in one sentence.",
        "timeout_seconds": 180,
        "env_vars": [
          "ANTHROPIC_API_KEY",
          "ANTHROPIC_OAUTH_TOKEN",
          "OPENAI_API_KEY",
          "AZURE_OPENAI_API_KEY",
          "DEEPSEEK_API_KEY",
          "GEMINI_API_KEY",
          "GROQ_API_KEY",
          "CEREBRAS_API_KEY",
          "XAI_API_KEY",
          "FIREWORKS_API_KEY",
          "TOGETHER_API_KEY",
          "OPENROUTER_API_KEY",
          "AI_GATEWAY_API_KEY",
          "ZAI_API_KEY",
          "MISTRAL_API_KEY",
          "MINIMAX_API_KEY",
          "MOONSHOT_API_KEY",
          "OPENCODE_API_KEY",
          "KIMI_API_KEY",
          "CLOUDFLARE_API_KEY",
          "XIAOMI_API_KEY",
          "AWS_BEARER_TOKEN_BEDROCK"
        ],
        "credential_files": ["~/.pi/agent/auth.json"],
        "support_files": ["~/.pi/agent/settings.json"],
        "discover_session": {
          "kind": "jsonl_newest",
          "roots": [".pi/agent/sessions"],
          "globs": ["**/*.jsonl"],
          "required_types": ["session", "message"]
        }
      }
    }
  }
}
